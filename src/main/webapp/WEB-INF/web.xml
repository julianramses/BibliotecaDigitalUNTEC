<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0"
         metadata-complete="false">

    <display-name>Biblioteca Digital UNTEC</display-name>
    <description>Sistema de gestión de biblioteca digital - Módulo 5 Java EE</description>

    <!-- Página de bienvenida: redirige al login -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Configuración de sesiones: 30 minutos de inactividad -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!--
        EncodingFilter: registrado SOLO aquí (sin @WebFilter en la clase).
        Doble registro (anotación + web.xml) rompe el enrutamiento de Servlets.
    -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.untec.biblioteca.controller.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Página de error 404 -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

    <!-- Página de error 500 -->
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

</web-app>
